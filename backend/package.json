{
  "name": "zentria-backend",
  "version": "0.1.0",
  "description": "Zentria Tracking API - Fastify + PostgreSQL + Redis",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "db:migrate": "node scripts/migrate.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "disposable-email-domains": "^1.0.62",
    "fastify": "^4.26.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
