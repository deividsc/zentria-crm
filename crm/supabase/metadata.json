{
  "schemas": {
    "public": {
      "tables": [
        {
          "name": "leads",
          "description": "Tabla principal de leads capturados desde landings"
        },
        {
          "name": "lead_events",
          "description": "Eventos de tracking de comportamiento"
        },
        {
          "name": "sync_logs",
          "description": "Logs de sincronización con Odoo"
        }
      ]
    }
  },
  "tables": [
    {
      "table": "leads",
      "columns": [
        { "name": "id", "type": "uuid", "primary": true },
        { "name": "email", "type": "varchar", "nullable": false },
        { "name": "name", "type": "varchar" },
        { "name": "phone", "type": "varchar" },
        { "name": "company", "type": "varchar" },
        { "name": "source", "type": "varchar", "description": "Origen del lead (landing_1, landing_2)" },
        { "name": "utm_source", "type": "varchar" },
        { "name": "utm_medium", "type": "varchar" },
        { "name": "utm_campaign", "type": "varchar" },
        { "name": "utm_content", "type": "varchar" },
        { "name": "utm_term", "type": "varchar" },
        { "name": "page_visited", "type": "varchar" },
        { "name": "scroll_depth", "type": "integer", "default": 0 },
        { "name": "time_on_page", "type": "integer", "default": 0 },
        { "name": "form_submitted", "type": "boolean", "default": false },
        { "name": "form_data", "type": "jsonb" },
        { "name": "ip_address", "type": "inet" },
        { "name": "user_agent", "type": "text" },
        { "name": "country", "type": "varchar" },
        { "name": "city", "type": "varchar" },
        { "name": "metadata", "type": "jsonb" },
        { "name": "odoo_lead_id", "type": "integer", "description": "ID del lead en Odoo" },
        { "name": "synced", "type": "boolean", "default": false },
        { "name": "created_at", "type": "timestamptz", "default": "now()" },
        { "name": "updated_at", "type": "timestamptz", "default": "now()" }
      ],
      "indexes": [
        "idx_leads_email",
        "idx_leads_source",
        "idx_leads_created",
        "idx_leads_unsynced"
      ]
    },
    {
      "table": "lead_events",
      "columns": [
        { "name": "id", "type": "uuid", "primary": true },
        { "name": "lead_id", "type": "uuid", "references": "leads(id)" },
        { "name": "event_type", "type": "varchar", "nullable": false },
        { "name": "event_data", "type": "jsonb" },
        { "name": "page_url", "type": "varchar" },
        { "name": "created_at", "type": "timestamptz", "default": "now()" }
      ]
    },
    {
      "table": "sync_logs",
      "columns": [
        { "name": "id", "type": "uuid", "primary": true },
        { "name": "source", "type": "varchar", "nullable": false },
        { "name": "records_processed", "type": "integer" },
        { "name": "records_success", "type": "integer" },
        { "name": "records_failed", "type": "integer" },
        { "name": "error_message", "type": "text" },
        { "name": "started_at", "type": "timestamptz", "default": "now()" },
        { "name": "completed_at", "type": "timestamptz" }
      ]
    }
  ],
  "functions": [
    {
      "name": "create_lead",
      "description": "Crea o actualiza un lead desde webhook",
      "args": [{ "name": "lead_data", "type": "jsonb" }],
      "returns": "leads"
    },
    {
      "name": "create_lead_event",
      "description": "Registra un evento de tracking",
      "args": [
        { "name": "p_lead_id", "type": "uuid" },
        { "name": "p_event_type", "type": "varchar" },
        { "name": "p_event_data", "type": "jsonb" },
        { "name": "p_page_url", "type": "varchar" }
      ],
      "returns": "lead_events"
    },
    {
      "name": "get_unsynced_leads",
      "description": "Obtiene leads pendientes de sincronizar",
      "args": [],
      "returns": "SETOF leads"
    },
    {
      "name": "mark_leads_synced",
      "description": "Marca leads como sincronizados",
      "args": [
        { "name": "lead_ids", "type": "uuid[]" },
        { "name": "p_odoo_lead_id", "type": "integer" }
      ],
      "returns": "void"
    },
    {
      "name": "create_sync_log",
      "description": "Registra un log de sincronización",
      "args": [
        { "name": "p_source", "type": "varchar" },
        { "name": "p_records_processed", "type": "integer" },
        { "name": "p_records_success", "type": "integer" },
        { "name": "p_records_failed", "type": "integer" },
        { "name": "p_error_message", "type": "text" }
      ],
      "returns": "sync_logs"
    }
  ]
}
