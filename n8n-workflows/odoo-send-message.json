      "typeVersion": 4.2,
      "position": [
        -480,
        200
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const cookie = ($json.headers['set-cookie'] || [''])[0].split(';')[0];\nconst prev = $('Validate & Normalize').item.json;\nreturn [{ json: { ...prev, cookie } }];"
      },
      "id": "0fad1eea-8951-4e85-ae76-89362054bb1a",
      "name": "Store Cookie (Email)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Send email via Odoo mail.mail\nconst data = $json;\n\nconst emailBody = JSON.stringify({\n  jsonrpc: '2.0',\n  method: 'call',\n  params: {\n    model: 'mail.mail',\n    method: 'create',\n    args: [{\n      subject:      `Mensaje de ${data.senderName}`,\n      body_html:    `<p>${data.message.replace(/\\n/g, '<br/>')}</p>`,\n      email_to:     data.email,\n      auto_delete:  true,\n    }],\n    kwargs: { context: {} }\n  }\n});\n\nconst sendBody = JSON.stringify({\n  jsonrpc: '2.0',\n  method: 'call',\n  params: {\n    model: 'mail.mail',\n    method: 'send',\n    args: [],  // will be set after create\n    kwargs: { context: {} }\n  }\n});\n\nreturn [{ json: { ...data, emailBody } }];"
      },
      "id": "c8a09abe-759b-4b3e-b2bc-5ea7d60b9a5c",
      "name": "Build Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.ODOO_URL }}/web/dataset/call_kw",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Cookie",
              "value": "={{ $json.cookie }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.emailBody }}",
        "options": {}
      },
      "id": "214c67be-c5c6-4dfb-bc9b-2d6072feb646",
      "name": "Create & Send Email",
