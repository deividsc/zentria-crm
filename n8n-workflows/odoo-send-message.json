      "id": "e60c63d4-7634-4754-b3b8-763cd2dd8591",
      "name": "Odoo Auth (Chatter)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        -200
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const cookie = ($json.headers['set-cookie'] || [''])[0].split(';')[0];\n// Merge back input data from before the send\nlet prev;\ntry { prev = $('Validate & Normalize').item.json; } catch { prev = {}; }\nconst waResult = $('Send via WhatsApp').item?.json || {};\nreturn [{ json: { ...prev, cookie, waSuccess: waResult.ok === true } }];"
      },
      "id": "e629a430-727e-40c1-9ee5-9ad410460a32",
      "name": "Store Cookie (Chatter)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        -200
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $json;\n\nif (!data.leadId && !data.partnerId) {\n  return [{ json: { ...data, skipChatter: true } }];\n}\n\nconst model  = data.leadId ? 'crm.lead' : 'res.partner';\nconst resId  = data.leadId || data.partnerId;\n\nconst channelEmoji = { whatsapp: '??', email: '??' };\nconst emoji = channelEmoji[data.channel] || '??';\n\nconst bodyHtml = `<p>${emoji} <strong>${data.senderName}</strong> envi� por <strong>${data.channel}</strong>:</p><p>${data.message.replace(/\\n/g, '<br/>')}</p>`;\n\nconst chatBody = JSON.stringify({\n  jsonrpc: '2.0',\n  method: 'call',\n  params: {\n    model,\n    method: 'message_post',\n    args: [resId],\n    kwargs: {\n      body: bodyHtml,\n      message_type: 'comment',\n      subtype_xmlid: 'mail.mt_note',\n      context: {}\n    }\n  }\n});\n\nreturn [{ json: { ...data, model, resId, chatBody, skipChatter: false } }];"
      },
      "id": "e6b14592-17c9-4f76-8c47-2e7778e0eb59",
      "name": "Build Chatter Log",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        -200
      ]
    },
