    {
      "parameters": {
        "jsCode": "const body = $json.body;\n\n// Validate required fields\nconst required = ['channel', 'message'];\nconst missing = required.filter(f => !body[f]);\nif (missing.length) throw new Error('Missing fields: ' + missing.join(', '));\n\n// At least phone (for whatsapp) or email must be present\nif (body.channel === 'whatsapp' && !body.phone) {\n  throw new Error('phone is required for whatsapp channel');\n}\nif (body.channel === 'email' && !body.email) {\n  throw new Error('email is required for email channel');\n}\n\n// Validate apiKey\nconst expectedKey = $env.INTERNAL_API_KEY || '';\nif (expectedKey && body.apiKey !== expectedKey) {\n  throw new Error('Unauthorized');\n}\n\nconst phone = body.phone ? String(body.phone).replace(/[\\s\\-().]/g, '') : null;\n\nreturn [{\n  json: {\n    channel:    body.channel,        // 'whatsapp' | 'email'\n    phone,\n    email:      body.email || null,\n    message:    body.message,\n    leadId:     body.leadId || null,  // optional � to log in chatter\n    partnerId:  body.partnerId || null,\n    senderName: body.senderName || 'Asesor',\n  }\n}];"
      },
      "id": "cd729cb1-d2a8-4c11-983d-b220e7b1a97e",
      "name": "Validate & Normalize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -960,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 1
          },
          "conditions": [
            {
              "id": "cond-channel",
              "leftValue": "={{ $json.channel }}",
              "rightValue": "whatsapp",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "2893eeff-17c3-4925-b7fb-3c2b943acfd3",
      "name": "Route by Channel",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
