    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.ODOO_URL }}/web/session/authenticate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"jsonrpc\": \"2.0\", \"method\": \"call\", \"params\": { \"db\": \"odoo\", \"login\": \"admin\", \"password\": \"admin\" } }",
        "options": {
