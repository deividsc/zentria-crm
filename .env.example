# Zentria Tracking SDK - Environment Configuration

# Application
NODE_ENV=development
API_PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=zentria
DB_PASSWORD=zentria_dev
DB_NAME=zentria_tracking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Authentication
API_KEY=your_secret_api_key_here

# SDK
SDK_ENDPOINT=http://localhost:3000/api/v1/events

# ─── Odoo ─────────────────────────────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB_NAME=odoo
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=change_me_odoo_db
ODOO_API_USER=admin
ODOO_API_PASSWORD=change_me_odoo_admin

# ─── n8n ──────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n
N8N_ENCRYPTION_KEY=change_me_32char_random_string__
N8N_TIMEZONE=Europe/Madrid

# ─── n8n PostgreSQL credentials (tracking DB) ─────────
N8N_PG_READER_USER=n8n_reader
N8N_PG_READER_PASSWORD=change_me_reader
N8N_PG_WRITER_USER=n8n_writer
N8N_PG_WRITER_PASSWORD=change_me_writer
