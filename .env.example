# ─────────────────────────────────────────────────────────
# Template de configuración — NUNCA commitear .env real.
#
# Dev local:   cp .env.local .env
# Producción:  cp .env.production .env   (solo antes de deploy)
# ─────────────────────────────────────────────────────────

# Tracking Stack
NODE_ENV=development
PORT=3000
API_PORT=3000
DB_HOST=localhost
DB_PORT=5433
DB_USER=zentria
DB_PASSWORD=zentria_dev
DB_NAME=zentria_tracking
REDIS_HOST=localhost
REDIS_PORT=6379
CORS_ORIGIN=*
API_KEY=your_api_key_here

# Odoo
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=change_me
ODOO_DB_NAME=odoo
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_LOGIN=admin
ODOO_PASSWORD=change_me

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_USER_EMAIL=your@email.com
N8N_USER_PASSWORD=change_me
N8N_ENCRYPTION_KEY=change_me_32char_random_string__
N8N_TIMEZONE=Europe/Madrid
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change_me

# n8n PostgreSQL credentials (tracking DB)
N8N_PG_READER_USER=n8n_reader
N8N_PG_READER_PASSWORD=change_me
N8N_PG_WRITER_USER=n8n_writer
N8N_PG_WRITER_PASSWORD=change_me

# Landing webhook
WEBHOOK_TOKEN=change_me
WEBHOOK_URL=http://localhost:5678/webhook/lead-webform
